ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-to-a-long-random-string

# ===== Google OAuth (Drive 連携) =====
# Google Cloud Console で OAuth 2.0 Client (Web) を作成し、
# Authorized redirect URI に http://localhost:3001/api/google/callback を追加する。
# 必要なスコープ: https://www.googleapis.com/auth/drive.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/google/callback
# 同期対象のフォルダID（Drive URLの最後のID部分）
GOOGLE_DRIVE_FOLDER_ID=1TjYHBL5quiuQPRbwqJcMoWpck_ZP349t
